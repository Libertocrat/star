#!/usr/bin/env bash
set -Eeuo pipefail

STAR_CLI_VERSION="0.1.0"

STAR_CLI_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
STAR_RUNTIME_DIR="${STAR_CLI_DIR}/star-runtime"
STAR_SCRIPTS_DIR="${STAR_RUNTIME_DIR}/scripts"
STAR_COMMON_FILE="${STAR_SCRIPTS_DIR}/helpers/common.sh"
STAR_BANNER_FILE="${STAR_SCRIPTS_DIR}/assets/star-banner.txt"

readonly STAR_CLI_VERSION
readonly STAR_CLI_DIR
readonly STAR_COMMON_FILE
readonly STAR_BANNER_FILE

COMMON_SOURCED=false

ROOT_AUTO_MODE=false
ROOT_DEMO_MODE=false
ROOT_SILENT_MODE=false
ROOT_PRODUCTION_MODE=false

STAR_ROOT_COLOR_RESET='\033[0m'
STAR_ROOT_COLOR_INFO='\033[36m'
STAR_ROOT_COLOR_WARN='\033[33m'
STAR_ROOT_COLOR_ERROR='\033[31m'

info() {
	printf '%b[INFO]%b %s\n' "${STAR_ROOT_COLOR_INFO}" "${STAR_ROOT_COLOR_RESET}" "$*"
}

warn() {
	printf '%b[WARN]%b %s\n' "${STAR_ROOT_COLOR_WARN}" "${STAR_ROOT_COLOR_RESET}" "$*" >&2
}

error() {
	printf '%b[ERROR]%b %s\n' "${STAR_ROOT_COLOR_ERROR}" "${STAR_ROOT_COLOR_RESET}" "$*" >&2
}

die() {
	error "$*"
	exit 1
}

command_exists() {
	local cmd="${1:?command is required}"
	command -v "${cmd}" >/dev/null 2>&1
}

usage() {
	cat <<'EOF'
Usage:
  ./star [options]
  ./star <command> [command options]

Description:
  The "star" command is the local control tool for STAR - Secure Templated Actions Runtime.

Commands:
  configure    Generate .env, secrets, and runtime directories
  up           Start the STAR Docker Compose runtime
  down         Stop the STAR runtime
  demo         Run guided STAR API demos
  status       Show local runtime status
  logs         Show STAR runtime logs
  help         Show this help

Global options (no command):
  --auto        Configure and start STAR using defaults
  --demo        Run the guided demo after startup
  --silent      Run non-interactively with minimal output
  --production  Use production-oriented configure/start behavior
  -h, --help    Show this help
  --version     Show star orchestrator version

Examples:
  ./star
  ./star --auto
  ./star --auto --demo
  ./star --silent
  ./star --production
  ./star configure
  ./star configure --auto
  ./star up --pull
  ./star demo --demo encrypt
  ./star status
  ./star logs -f
  ./star down

Command help:
  ./star configure --help
  ./star up --help
  ./star down --help
  ./star demo --help
EOF
}

status_usage() {
	cat <<'EOF'
Usage:
  ./star status

Description:
  Inspect local STAR package, configuration, and runtime state.
EOF
}

logs_usage() {
	cat <<'EOF'
Usage:
  ./star logs [options]

Options:
  -f, --follow    Follow log output
  --tail <N>      Show the last N lines (default: 120)
  -h, --help      Show this help

Examples:
  ./star logs
  ./star logs -f
  ./star logs --tail 200
  ./star logs -f --tail 200
EOF
}

print_version() {
	printf 'star %s\n' "${STAR_CLI_VERSION}"
}

validate_deployment_package() {
	local missing=()
	local required_path=''
	local required_dir=''
	local -a required_files=(
		"star-runtime/docker-compose.yml"
		"star-runtime/scripts/star-configure.sh"
		"star-runtime/scripts/star-up.sh"
		"star-runtime/scripts/star-down.sh"
		"star-runtime/scripts/star-demo.sh"
		"star-runtime/scripts/helpers/common.sh"
		"star-runtime/scripts/helpers/star-api.sh"
		"star-runtime/scripts/demos/demo-common.sh"
		"star-runtime/scripts/demos/demo-deps.sh"
		"star-runtime/scripts/demos/demo-flows.sh"
		"star-runtime/scripts/demos/assets/demo-text.txt"
	)

	required_dir="${STAR_CLI_DIR}/star-runtime"
	if [[ ! -d "${required_dir}" ]]; then
		missing+=("star-runtime/")
	fi

	for required_path in "${required_files[@]}"; do
		if [[ ! -f "${STAR_CLI_DIR}/${required_path}" ]]; then
			missing+=("${required_path}")
		fi
	done

	if (( ${#missing[@]} == 0 )); then
		return 0
	fi

	error "STAR deployment package looks incomplete."
	for required_path in "${missing[@]}"; do
		error "Missing required file: ${required_path}"
	done
	error "Re-download and extract the STAR deployment package."
	return 1
}

source_common() {
	if [[ "${COMMON_SOURCED}" == "true" ]]; then
		return 0
	fi

	if [[ ! -f "${STAR_COMMON_FILE}" ]]; then
		error "Missing required file: star-runtime/scripts/helpers/common.sh"
		return 1
	fi

	# shellcheck disable=SC1091
	# shellcheck source=star-runtime/scripts/helpers/common.sh
	source "${STAR_COMMON_FILE}"
	COMMON_SOURCED=true
	return 0
}

print_banner() {
	if [[ "${ROOT_SILENT_MODE}" == "true" ]]; then
		return 0
	fi

	if [[ -f "${STAR_BANNER_FILE}" ]]; then
		cat "${STAR_BANNER_FILE}"
		printf '\n'
		return 0
	fi

	cat <<'EOF'
  ____   ______   ___    ____
 / ___| |_   _|  / _ \  |  _ \
 \___ \   | |   / /_\ \ | |_) |
  ___) |  | |   |  _  | |  _ <
 |____/   |_|   |_| |_| |_| \_\   v0.1.0

 Secure Templated Actions Runtime
 Safe actions. No raw shell.
EOF
	printf '\n'
}

run_command() {
	"$@"
}

run_command_silent() {
	local output=''
	local status=0

	if output="$({ "$@"; } 2>&1)"; then
		return 0
	fi

	status=$?
	if [[ -n "${output}" ]]; then
		printf '%s\n' "${output}" >&2
	fi

	return "${status}"
}

run_runtime_script() {
	local script_path="${1:?script path is required}"
	local quiet_mode="${2:-false}"
	shift 2 || true

	if [[ ! -f "${script_path}" ]]; then
		error "Missing required file: ${script_path}"
		return 1
	fi

	if [[ "${quiet_mode}" == "true" ]]; then
		if [[ -x "${script_path}" ]]; then
			run_command_silent "${script_path}" "$@"
		else
			run_command_silent bash "${script_path}" "$@"
		fi
		return $?
	fi

	if [[ -x "${script_path}" ]]; then
		run_command "${script_path}" "$@"
	else
		run_command bash "${script_path}" "$@"
	fi
}

has_env_file() {
	[[ -f "${STAR_RUNTIME_DIR}/.env" ]]
}

has_token_file() {
	[[ -f "${STAR_RUNTIME_DIR}/secrets/star_api_token.txt" ]]
}

token_is_valid() {
	local token=''

	if ! token="$(read_token 2>/dev/null)"; then
		return 1
	fi

	validate_token_strength "${token}"
}

runtime_appears_running() {
	local running_services=''

	if ! has_env_file; then
		return 1
	fi

	if ! command_exists docker; then
		return 1
	fi

	if ! docker info >/dev/null 2>&1; then
		return 1
	fi

	if ! docker compose version >/dev/null 2>&1; then
		return 1
	fi

	if ! running_services="$(docker compose --env-file "${STAR_RUNTIME_DIR}/.env" -f "${STAR_RUNTIME_DIR}/docker-compose.yml" ps --status running --services 2>/dev/null)"; then
		return 1
	fi

	grep -qx 'star-core' <<<"${running_services}"
}

health_is_reachable() {
	if ! command_exists curl; then
		return 1
	fi

	curl -fsS "$(health_url)" >/dev/null 2>&1
}

docs_are_enabled() {
	local docs_flag="${STAR_ENABLE_DOCS:-false}"
	docs_flag="${docs_flag,,}"

	case "${docs_flag}" in
		true|1|yes|y)
			return 0
			;;
		*)
			return 1
			;;
	esac
}

docs_are_reachable() {
	if ! command_exists curl; then
		return 1
	fi

	curl -fsS "$(docs_url)" >/dev/null 2>&1
}

ensure_existing_auto_configuration_is_valid() {
	if ! has_env_file; then
		return 1
	fi

	load_env required

	if ! has_token_file || ! token_is_valid; then
		error "STAR configuration exists, but the API token is missing or invalid."
		error "Run: ./star configure"
		return 1
	fi

	return 0
}

run_configure_command() {
	validate_deployment_package || return 1
	source_common || return 1

	run_runtime_script "${STAR_SCRIPTS_DIR}/star-configure.sh" "false" "$@"
}

run_up_command() {
	validate_deployment_package || return 1
	source_common || return 1

	run_runtime_script "${STAR_SCRIPTS_DIR}/star-up.sh" "false" "$@"
}

run_down_command() {
	validate_deployment_package || return 1
	source_common || return 1

	run_runtime_script "${STAR_SCRIPTS_DIR}/star-down.sh" "false" "$@"
}

run_demo_command() {
	validate_deployment_package || return 1
	source_common || return 1

	print_banner
	run_runtime_script "${STAR_SCRIPTS_DIR}/star-demo.sh" "false" "$@"
}

status_ok() {
	local label="${1:-}"
	local value="${2:-}"
	printf '  %b+%b %-27s %s\n' "${STAR_COLOR_OK:-}" "${STAR_COLOR_RESET:-}" "${label}" "${value}"
}

status_warn() {
	local label="${1:-}"
	local value="${2:-}"
	printf '  %b!%b %-27s %s\n' "${STAR_COLOR_WARN:-}" "${STAR_COLOR_RESET:-}" "${label}" "${value}"
}

status_error() {
	local label="${1:-}"
	local value="${2:-}"
	printf '  %bx%b %-27s %s\n' "${STAR_COLOR_ERROR:-}" "${STAR_COLOR_RESET:-}" "${label}" "${value}"
}

status_info() {
	local label="${1:-}"
	local value="${2:-}"
	printf '  %b-%b %-27s %s\n' "${STAR_COLOR_INFO:-}" "${STAR_COLOR_RESET:-}" "${label}" "${value}"
}

compose_runtime() {
	docker compose --env-file "${STAR_RUNTIME_DIR}/.env" -f "${STAR_RUNTIME_DIR}/docker-compose.yml" "$@"
}

run_status_command() {
	local docker_ready=false
	local compose_ready=false
	local env_loaded=false
	local service_running=false
	local inspect_failed=false
	local running_services=''
	local compose_project='star'
	local docker_network='star-network'
	local docker_volume='star_star-data'

	if [[ $# -gt 0 ]]; then
		case "${1}" in
			-h|--help)
				status_usage
				return 0
				;;
			*)
				error "Unknown argument for status: ${1}"
				status_usage
				return 2
				;;
		esac
	fi

	validate_deployment_package || return 1
	source_common || return 1

	section 'STAR Status'
    printf '\n'

	printf 'Package:\n'
	status_ok "Runtime assets" "valid"

	printf '\nConfiguration:\n'
	if has_env_file; then
		load_env required
		env_loaded=true
		status_ok ".env" "ready"
	else
		status_warn ".env" "missing (run: ./star configure)"
	fi

	if token_is_valid; then
		status_ok "API token" "valid"
	elif has_token_file; then
		status_error "API token" "invalid"
	else
		status_warn "API token" "missing"
	fi

	if [[ "${env_loaded}" == "true" ]]; then
		compose_project="${COMPOSE_PROJECT_NAME:-star}"
		docker_network="${STAR_SHARED_NETWORK:-star-network}"
		docker_volume="${STAR_DATA_VOLUME:-${compose_project}_star-data}"
	fi

	status_info "Compose project" "${compose_project}"
	status_info "Docker network" "${docker_network}"
	status_info "Docker volume" "${docker_volume}"

	printf '\nRuntime:\n'
	if ! command_exists docker; then
		status_error "Docker" "CLI not found"
		inspect_failed=true
	elif ! docker info >/dev/null 2>&1; then
		status_error "Docker" "daemon unreachable"
		inspect_failed=true
	else
		docker_ready=true
		status_ok "Docker" "reachable"
	fi

	if [[ "${docker_ready}" == "true" ]]; then
		if docker compose version >/dev/null 2>&1; then
			compose_ready=true
			status_ok "Docker Compose" "available"
		else
			status_error "Docker Compose" "unavailable"
			inspect_failed=true
		fi
	else
		status_info "Docker Compose" "not checked"
	fi

	if [[ "${env_loaded}" == "true" && "${docker_ready}" == "true" && "${compose_ready}" == "true" ]]; then
		if ! running_services="$(compose_runtime ps --status running --services 2>/dev/null)"; then
			status_error "Service" "failed to inspect"
			inspect_failed=true
		elif grep -qx 'star-core' <<<"${running_services}"; then
			service_running=true
			status_ok "Service" "running"
		else
			status_warn "Service" "not running"
		fi
	elif [[ "${env_loaded}" == "true" ]]; then
		status_info "Service" "not checked"
	else
		status_info "Service" "not configured"
	fi

	if [[ "${service_running}" == "true" ]]; then
		if command_exists curl; then
			if health_is_reachable; then
				status_ok "Health" "$(health_url)"
			else
				status_error "Health" "unreachable at $(health_url)"
			fi

			if docs_are_enabled; then
				if docs_are_reachable; then
					status_ok "Swagger / OpenAPI docs" "$(docs_url)"
				else
					status_error "Swagger / OpenAPI docs" "unreachable at $(docs_url)"
				fi
			else
				status_info "Swagger / OpenAPI docs" "disabled"
			fi
		else
			status_warn "Health" "curl not found; endpoint check skipped"
			if docs_are_enabled; then
				status_warn "Swagger / OpenAPI docs" "curl not found; endpoint check skipped"
			else
				status_info "Swagger / OpenAPI docs" "disabled"
			fi
		fi
	elif [[ "${service_running}" == "false" && "${env_loaded}" == "true" ]]; then
		status_info "Health" "not checked (service not running)"
		if docs_are_enabled; then
			status_info "Swagger / OpenAPI docs" "not checked (service not running)"
		else
			status_info "Swagger / OpenAPI docs" "disabled"
		fi
	fi

	if [[ "${inspect_failed}" == "true" ]]; then
		return 1
	fi

	return 0
}

run_logs_command() {
	local follow_mode=false
	local tail_lines='120'
	local -a logs_args=("logs" "--tail=120" "star-core")

	while [[ $# -gt 0 ]]; do
		case "$1" in
			-f|--follow)
				follow_mode=true
				shift
				;;
			--tail)
				if [[ $# -lt 2 ]]; then
					error "--tail requires an integer value."
					logs_usage
					return 2
				fi
				tail_lines="$2"
				shift 2
				;;
			--tail=*)
				tail_lines="${1#*=}"
				shift
				;;
			-h|--help)
				logs_usage
				return 0
				;;
			*)
				error "Unknown logs argument: $1"
				logs_usage
				return 2
				;;
		esac
	done

	if [[ ! "${tail_lines}" =~ ^[0-9]+$ ]]; then
		error "--tail must be a non-negative integer."
		return 2
	fi

	validate_deployment_package || return 1
	source_common || return 1

	if ! has_env_file; then
		error "STAR runtime is not configured. Run: ./star configure"
		return 1
	fi

	load_env required

	if ! command_exists docker; then
		die "Docker CLI is required but was not found in PATH."
	fi

	if ! docker info >/dev/null 2>&1; then
		die "Docker daemon is not reachable. Start Docker and try again."
	fi

	if ! docker compose version >/dev/null 2>&1; then
		die "Docker Compose v2 is required. Ensure 'docker compose' is available."
	fi

	if ! runtime_appears_running; then
		warn "STAR runtime does not appear to be running. Run: ./star up"
	fi

	if command_exists curl; then
		if ! health_is_reachable; then
			warn "STAR health endpoint is unreachable at $(health_url)"
		fi
	else
		warn "curl was not found; skipping health endpoint check."
	fi

	logs_args=("logs" "--tail=${tail_lines}" "star-core")
	if [[ "${follow_mode}" == "true" ]]; then
		logs_args=("logs" "-f" "--tail=${tail_lines}" "star-core")
	fi

	run_command compose_runtime "${logs_args[@]}"
}

run_global_auto_flow() {
	local -a configure_args=("--auto")
	local -a up_args=()

	if [[ "${ROOT_PRODUCTION_MODE}" == "true" ]]; then
		configure_args+=("--production")
		up_args+=("--production")
	fi

	if ! has_env_file; then
		if [[ "${ROOT_SILENT_MODE}" == "true" ]]; then
			run_runtime_script "${STAR_SCRIPTS_DIR}/star-configure.sh" "true" "${configure_args[@]}"
		else
			run_runtime_script "${STAR_SCRIPTS_DIR}/star-configure.sh" "false" "${configure_args[@]}"
		fi
	else
		ensure_existing_auto_configuration_is_valid || return 1
	fi

	if [[ "${ROOT_SILENT_MODE}" == "true" ]]; then
		up_args+=("--silent")
		run_runtime_script "${STAR_SCRIPTS_DIR}/star-up.sh" "true" "${up_args[@]}"
	else
		run_runtime_script "${STAR_SCRIPTS_DIR}/star-up.sh" "false" "${up_args[@]}"
	fi

	if [[ "${ROOT_DEMO_MODE}" == "true" ]]; then
		run_runtime_script "${STAR_SCRIPTS_DIR}/star-demo.sh" "false" "--auto"
	fi
}

run_global_interactive_flow() {
	local ran_configure=false
	local started_runtime=false
	local demo_ready=false
	local -a configure_args=()
	local -a up_args=()

	if [[ "${ROOT_PRODUCTION_MODE}" == "true" ]]; then
		configure_args+=("--production")
		up_args+=("--production")
	fi

	if ! has_env_file; then
		info "STAR configuration was not found."
		if ! confirm "Run configuration wizard now?" "Y"; then
			info "Configuration skipped. Run ./star configure when ready."
			return 0
		fi

		run_runtime_script "${STAR_SCRIPTS_DIR}/star-configure.sh" "false" "${configure_args[@]}"
		ran_configure=true
	fi

	if ! has_env_file; then
		error "STAR configuration was not created."
		error "Run: ./star configure"
		return 1
	fi

	load_env required

	if ! token_is_valid; then
		error "STAR configuration exists, but the API token is missing or invalid."
		error "Run: ./star configure"
		return 1
	fi

	if runtime_appears_running; then
		success "STAR runtime is already running."
	else
		if [[ "${ran_configure}" == "true" ]]; then
			if confirm "Start STAR now?" "Y"; then
				run_runtime_script "${STAR_SCRIPTS_DIR}/star-up.sh" "false" "${up_args[@]}"
				started_runtime=true
			fi
		else
			if confirm "Start STAR now?" "Y"; then
				run_runtime_script "${STAR_SCRIPTS_DIR}/star-up.sh" "false" "${up_args[@]}"
				started_runtime=true
			fi
		fi
	fi

	if [[ "${ROOT_DEMO_MODE}" == "true" ]]; then
		if [[ "${started_runtime}" == "true" ]] || runtime_appears_running; then
			demo_ready=true
		fi

		if [[ "${demo_ready}" == "true" ]]; then
			if confirm "Run guided demo now?" "Y"; then
				run_runtime_script "${STAR_SCRIPTS_DIR}/star-demo.sh" "false"
			fi
		fi
	elif [[ "${started_runtime}" == "false" ]]; then
		info "Next steps: ./star demo, ./star status, ./star logs -f"
	fi

	return 0
}

run_global_flow() {
	validate_deployment_package || return 1
	source_common || return 1

	if [[ "${ROOT_SILENT_MODE}" == "true" && "${ROOT_DEMO_MODE}" == "true" ]]; then
		error "--silent cannot be combined with --demo."
		return 2
	fi

	if [[ "${ROOT_SILENT_MODE}" == "true" ]]; then
		ROOT_AUTO_MODE=true
	fi

	if [[ "${ROOT_AUTO_MODE}" == "true" ]]; then
		run_global_auto_flow
		return $?
	fi

	run_global_interactive_flow
}

parse_global_flags() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--auto)
				ROOT_AUTO_MODE=true
				shift
				;;
			--demo)
				ROOT_DEMO_MODE=true
				shift
				;;
			--silent)
				ROOT_SILENT_MODE=true
				ROOT_AUTO_MODE=true
				shift
				;;
			--production)
				ROOT_PRODUCTION_MODE=true
				shift
				;;
			-h|--help)
				print_banner
				usage
				exit 0
				;;
			--version)
				print_version
				exit 0
				;;
			--*)
				error "Unknown option: $1"
				usage
				return 2
				;;
			*)
				error "Unsupported argument without command: $1"
				error "Global options cannot be used before a subcommand."
				usage
				return 2
				;;
		esac
	done

	return 0
}

dispatch_subcommand() {
	local command="${1:?command is required}"
	shift || true

	case "${command}" in
		configure)
			run_configure_command "$@"
			;;
		up)
			run_up_command "$@"
			;;
		down)
			run_down_command "$@"
			;;
		demo)
			run_demo_command "$@"
			;;
		status)
			run_status_command "$@"
			;;
		logs)
			run_logs_command "$@"
			;;
		help)
			print_banner
			usage
			;;
		*)
			error "Unknown command: ${command}"
			usage
			return 1
			;;
	esac
}

main() {
	if [[ $# -eq 0 ]]; then
		print_banner
		run_global_flow
		return $?
	fi

	case "$1" in
		configure|up|down|demo|status|logs|help)
			dispatch_subcommand "$@"
			;;
		-h|--help)
			print_banner
			usage
			;;
		--version)
			print_version
			;;
		--*)
			parse_global_flags "$@" || return $?

			if [[ "${ROOT_SILENT_MODE}" != "true" ]]; then
				print_banner
			fi

			run_global_flow
			;;
		*)
			error "Unknown command: $1"
			usage
			return 1
			;;
	esac
}

main "$@"

# =============================================================================
# Secure Templated Actions Runtime (STAR) - Environment Configuration
#
# Runtime: Python 3.12
#
# Copy this file to `.env` and populate secrets.
# NEVER commit the `.env` file to version control.
# =============================================================================
#
# Notes:
# - STAR is designed to run as a rootless container.
# - Filesystem access is restricted to a single root: STAR_ROOT_DIR.
# - File operations are constrained to the STAR-managed storage layout.
# - This file documents both REQUIRED and OPTIONAL configuration.
#
# =============================================================================


# =============================================================================
# Container Identity (Non-Root Execution)
# -----------------------------------------------------------------------------
# STAR always runs as a non-root user to reduce privilege and blast radius.
# These values define the security identity of the container and MUST be
# consistent with host-side volume permissions.
# =============================================================================

# Non-root user and group name inside the container
STAR_CONTAINER_USER=star
STAR_CONTAINER_GROUP=star

# Fixed UID/GID for deterministic permissions and persistent storage access
# NOTE:
# - Host-mounted volumes MUST use this GID for group ownership
# - setgid MUST be enabled on shared directories
STAR_CONTAINER_UID=1001
STAR_CONTAINER_GID=1001


# =============================================================================
# Docker / Compose Infrastructure
# -----------------------------------------------------------------------------
# Variables that define how STAR integrates into a Docker Compose stack.
# These values are consumed by docker-compose.yml, not by the application code.
# =============================================================================

# Docker Compose project name (used as a namespace for containers and volumes)
COMPOSE_PROJECT_NAME=star

# Docker volume name for STAR persistent data.
STAR_DATA_VOLUME=star_star-data

# Name of the pre-existing Docker network used to connect internal services
# (e.g. n8n, STAR, other microservices)
STAR_SHARED_NETWORK=docker-network

# Host interface used by Docker Compose when publishing STAR to the host.
# Default: 127.0.0.1
#
# Keep this set to 127.0.0.1 for local demos and development so STAR is only
# reachable from the host machine.
#
# Advanced users may set this to 0.0.0.0 to expose STAR on all host interfaces,
# but that should only be done intentionally and with proper network controls.
STAR_HOST_BIND_ADDRESS=127.0.0.1

# Host port published by Docker Compose for local access to STAR.
# This maps to STAR_PORT inside the container.
#
# Example:
#   Host URL:      http://localhost:8080
#   Container URL: http://star:8080
STAR_HOST_PORT=8080

# =============================================================================
# Security / Authentication
# -----------------------------------------------------------------------------
# STAR uses a single bearer token for internal service authentication.
# This token MUST be kept secret.
# =============================================================================

# STAR_API_TOKEN is loaded from Docker secret:
#   /run/secrets/star_api_token
#
# Create the local secret file (never commit real values):
#   mkdir -p secrets
#   openssl rand -hex 32 > secrets/star_api_token.txt
#
# Development-only fallback (used only when Docker secret is missing):
# STAR_API_TOKEN_DEV=


# =============================================================================
# STAR Persistent Storage Root
# -----------------------------------------------------------------------------
# Root directory where STAR keeps internal persistent data.
# STAR stores metadata, blobs and future internal assets under:
#   <STAR_ROOT_DIR>/data
# =============================================================================

# Absolute persistent storage root directory for STAR internal data.
STAR_ROOT_DIR=/var/lib/star


# =============================================================================
# Runtime Binary Execution Policy (Optional Extras)
# -----------------------------------------------------------------------------
# STAR actions compile allowlists strictly from DSL `binaries` and enforce a
# global blocklist at runtime. Only blocked binaries can be extended by env.
#
# Rules:
# - Values are comma-separated binary NAMES (no paths)
# - Paths are forbidden (for example: /bin/sh, ./tool, C:\\tool)
# - Extra entries are added to the default global blocklist
# - Blocked binaries can never be enabled by configuration
# =============================================================================

# Optional extra binaries to include in effective global blocklist.
# Example: bash,python3,curl
STAR_BLOCKED_BINARIES_EXTRA=


# =============================================================================
# Runtime Limits & Safeguards
# -----------------------------------------------------------------------------
# Hard limits to reduce blast radius and prevent abuse or accidental overload.
# =============================================================================

# Maximum allowed file size (in bytes) for file-based operations.
# Default: 100 MB
STAR_MAX_FILE_BYTES=104857600

# Maximum allowed size (in bytes) for DSL YAML spec files.
# Prevents memory abuse and parser attacks.
STAR_MAX_YML_BYTES=102400

# Maximum execution time per request (in milliseconds).
# Requests exceeding this time will be aborted.
STAR_TIMEOUT_MS=5000

# --- DSL / Runtime Output Hardening ---

# Maximum number of bytes returned in stdout after sanitization
STAR_MAX_STDOUT_BYTES=65536

# Maximum number of bytes returned in stderr after sanitization
STAR_MAX_STDERR_BYTES=65536

# Rate limit: maximum number of requests per second per client.
STAR_RATE_LIMIT_RPS=10


# =============================================================================
# Runtime Behavior
# -----------------------------------------------------------------------------
# Controls runtime metadata and behavior.
# =============================================================================

# Application semantic version used in runtime metadata/OpenAPI docs.
# Format: x.y.z
STAR_APP_VERSION=0.1.2

# Internal port where the FastAPI application listens inside the container.
# Docker Compose publishes this port to the host through STAR_HOST_PORT.
#
# Internal Docker URL:
#   http://star:8080
#
# Host URL, with default Compose settings:
#   http://localhost:8080
STAR_PORT=8080


# =============================================================================
# API Docs / Runtime UI toggle
# -----------------------------------------------------------------------------
# Controls whether FastAPI's interactive documentation endpoints are enabled
# =============================================================================

# `STAR_ENABLE_DOCS` controls unauthenticated OpenAPI and UI endpoints:
# `/docs`, `/redoc` and `/openapi.json`.
# Keep this disabled by default for security.
# Enable only during local development or internal testing.
# Never enable in production environments.
# When enabled and using the default Compose port mapping, docs are available at:
#   http://localhost:8080/docs
# Default: `false`.
STAR_ENABLE_DOCS=false

# =============================================================================
# Response Security Headers
# -----------------------------------------------------------------------------
# Controls baseline security headers and stack-fingerprinting header removal.
# =============================================================================

# When `STAR_ENABLE_SECURITY_HEADERS` is `true`, STAR adds baseline response
# security headers and removes `Server` / `X-Powered-By` from all HTTP responses.
# Default: `true` (recommended for production).
STAR_ENABLE_SECURITY_HEADERS=true

# =============================================================================
